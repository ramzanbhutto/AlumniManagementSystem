@page "/jobs"
@rendermode InteractiveWebAssembly
@inject NavigationManager Nav
@inject JobApiService Svc
@inject AuthService Auth
@inject ISnackbar Snackbar

<PageTitle>Job Board</PageTitle>

<MudStack Spacing="4">

    @* ── Header ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight:700;letter-spacing:-0.02em;color:#111827">Job Board</MudText>
            <MudText Typo="Typo.body2" Style="color:#6b7280">@_filtered.Count listings available</MudText>
        </div>
        @if(Auth.IsAlumni || Auth.IsAdmin){
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.Add"
                       OnClick="@(() => _showCreate = true)"
                       Style="border-radius:10px;font-weight:600;text-transform:none;padding:0.5rem 1.25rem">
                Post a Job
            </MudButton>
        }
    </MudStack>

    @* ── Filters ── *@
    <MudPaper Elevation="0" Style="background:#EDE7F6;border:1px solid #d1d5db;border-radius:14px;padding:1.1rem">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="5">
                <MudTextField @bind-Value="_search"
                              Placeholder="Search title or company..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Immediate="true" @bind-Value:after="ApplyFilters" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <NativeSelect Label="Job Type" Value="@_filterType" BgColor="#EDE7F6"
                              ValueChanged="@((string? v) => { _filterType = v ?? ""; ApplyFilters(); })">
                    <option value="">All Types</option>
                    @foreach(var t in _types){
                        <option value="@t">@t</option>
                    }
                </NativeSelect>
            </MudItem>
            <MudItem xs="6" sm="4">
                <MudTextField @bind-Value="_filterLocation"
                              Placeholder="Filter by location..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.LocationOn"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Immediate="true" @bind-Value:after="ApplyFilters" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── List ── *@
    @if(_loading){
        <MudStack Spacing="2">
            @for(int i = 0; i < 5; i++){
                <MudSkeleton Height="110px" Animation="Animation.Wave" Style="border-radius:14px" />
            }
        </MudStack>
    }
    else if(!_filtered.Any()){
        <MudPaper Elevation="0" Style="background:#EDE7F6;border:1px solid #e5e7eb;border-radius:14px;padding:3rem;text-align:center">
            <MudIcon Icon="@Icons.Material.Rounded.WorkOff" Style="font-size:3rem;color:#9ca3af;margin-bottom:0.75rem" />
            <MudText Typo="Typo.body1" Style="color:#6b7280">No jobs found matching your criteria</MudText>
        </MudPaper>
    }
    else{
        <MudStack Spacing="2">
            @foreach(var j in _filtered){
                <MudPaper Elevation="0" Class="job-card"
                          Style="background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;padding:1.25rem;transition:all 0.18s">
                    <MudStack Row="true" AlignItems="AlignItems.Start"
                              Justify="Justify.SpaceBetween" Class="flex-wrap gap-2">

                        @* Left content *@
                        <div style="flex:1;min-width:0">
                            @* Title + type chip *@
                            <MudStack Row="true" AlignItems="AlignItems.Center"
                                      Spacing="2" Class="mb-1 flex-wrap">
                                <MudText Typo="Typo.subtitle1"
                                         Style="font-weight:700;color:#111827;font-size:1rem">
                                    @j.Title
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@GetJobTypeColor(j.JobType)"
                                         Style="font-size:0.68rem;height:20px;font-weight:600">
                                    @j.JobType
                                </MudChip>
                            </MudStack>

                            @* Company *@
                            <MudText Typo="Typo.body2"
                                     Style="color:#374151;font-weight:600;margin-bottom:0.35rem">
                                @j.Company
                            </MudText>

                            @* Description *@
                            <MudText Typo="Typo.body2"
                                     Style="color:#6b7280;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;margin-bottom:0.5rem">
                                @j.Description
                            </MudText>

                            @* Meta row *@
                            <MudStack Row="true" Spacing="5" Class="flex-wrap">
                                @if(j.Location != null){
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Rounded.LocationOn"
                                                 Style="font-size:0.8rem;color:#6b7280" />
                                        <MudText Typo="Typo.caption" Style="color:#6b7280">@j.Location</MudText>
                                    </MudStack>
                                }
                                @if(j.SalaryRange != null){
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Rounded.Payments"
                                                 Style="font-size:0.8rem;color:#059669" />
                                        <MudText Typo="Typo.caption" Style="color:#059669;font-weight:600">
                                            @j.SalaryRange
                                        </MudText>
                                    </MudStack>
                                }
                                @if(!string.IsNullOrEmpty(j.PostedByName)){
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Rounded.Person"
                                                 Style="font-size:0.8rem;color:#9ca3af" />
                                        <MudText Typo="Typo.caption" Style="color:#9ca3af">@j.PostedByName</MudText>
                                    </MudStack>
                                }
                                @if(j.Deadline.HasValue){
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Rounded.Schedule"
                                                 Style="font-size:0.8rem;color:#d97706" />
                                        <MudText Typo="Typo.caption" Style="color:#d97706;font-weight:500">
                                            Deadline: @j.Deadline.Value.ToString("MMM d, yyyy")
                                        </MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        </div>

                        @* Apply button *@
                        @if(j.ApplicationUrl != null){
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       Size="Size.Small" Href="@j.ApplicationUrl" Target="_blank"
                                       Style="border-radius:8px;flex-shrink:0;text-transform:none;font-weight:600;align-self:center">
                                Apply →
                            </MudButton>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }

</MudStack>

@* Post Job Dialog *@
@if(_showCreate){
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="1000" />
    <div style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1001;padding:1rem">
        <MudPaper Elevation="0"
                  Style="background:#ffffff;border:1px solid #e5e7eb;border-radius:18px;padding:2rem;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.15)">

            @* Dialog header *@
            <MudStack Row="true" AlignItems="AlignItems.Center"
                      Justify="Justify.SpaceBetween" Class="mb-4">
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;color:#111827">Post a Job</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6b7280">Visible to all alumni and guests</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small"
                               OnClick="@(() => { _showCreate = false; _dto = new(){ JobType = "FullTime" }; })" />
            </MudStack>

            <MudForm @ref="_form" @bind-IsValid="_valid">
                <MudStack Spacing="3">

                    <MudTextField @bind-Value="_dto.Title" Label="Job Title"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Job title is required" />

                    <MudTextField @bind-Value="_dto.Company" Label="Company"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Company is required" />

                    <MudTextField @bind-Value="_dto.Description" Label="Description"
                                  Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense"
                                  Required="true" RequiredError="Description is required"
                                  HelperText="@($"{_dto.Description?.Length ?? 0}/5000")"
                                  Validation="@((string v) => (v?.Length ?? 0) < 20 ? "Minimum 20 characters required" : null)"
                                  MaxLength="5000"
                                  Immediate="true" />

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <NativeSelect Label="Job Type*" Value="@_dto.JobType" BgColor="#ffffff"
                                          ValueChanged="@((string? v) => _dto.JobType = v ?? "FullTime")">
                                @foreach(var t in _types){
                                    <option value="@t">@t</option>
                                }
                            </NativeSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_dto.Location" Label="Location"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="_dto.SalaryRange"
                                  Label="Salary Range (e.g. 80,000–120,000 PKR)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />

                    <MudTextField @bind-Value="_dto.ApplicationUrl" Label="Application URL"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  InputType="InputType.Url" />

                    <div>
                        <label style="display:block;font-size:0.75rem;color:#6b7280;margin-bottom:4px;font-weight:500">
                            Application Deadline
                        </label>
                        <input type="date"
                               value="@_deadline?.ToString("yyyy-MM-dd")"
                               @onchange="@((ChangeEventArgs ev) => _deadline = DateTime.TryParse(ev.Value?.ToString(), out var d) ? d : null)"
                               style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;
                                      background:#f9fafb;font-size:0.875rem;color:#111827;
                                      font-family:inherit;outline:none;height:38px;box-sizing:border-box" />
                    </div>

                    <MudDivider />

                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => { _showCreate = false; _dto = new(){ JobType = "FullTime" }; })"
                                   Style="text-transform:none">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="CreateAsync" Disabled="_saving"
                                   Style="border-radius:8px;text-transform:none;font-weight:600">
                            @if(_saving){
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Post Job
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudForm>
        </MudPaper>
    </div>
}

<style>
    .job-card:hover {
        border-color: #c4b5fd !important;
        box-shadow: 0 4px 20px rgba(124,58,237,0.08);
        transform: translateY(-1px);
    }
</style>

@code {
    private List<JobPostingDto> _all= [];
    private List<JobPostingDto> _filtered = [];
    private bool _loading = true;
    private bool _showCreate = false;
    private bool _saving= false;
    private bool _valid = false;
    private string _search  = "";
    private string _filterType= "";
    private string _filterLocation = "";
    private MudForm? _form;
    private CreateJobPostingDto _dto = new() { JobType = "FullTime" };
    private DateTime? _deadline = null;

    private string[] _types = ["FullTime", "PartTime", "Remote", "Contract"];

    protected override async Task OnAfterRenderAsync(bool firstRender){
        if(!firstRender) return;
        await Auth.InitAsync();
        if(!Auth.IsLoggedIn){ Nav.NavigateTo("/login"); return; }
        _all = await Svc.GetAllAsync();
        ApplyFilters();
        _loading = false;
        StateHasChanged();
    }

    private void ApplyFilters(){
        _filtered = _all.Where(j =>
        {
            var text = $"{j.Title} {j.Company}".ToLower();
            if(!string.IsNullOrEmpty(_search) &&
               !text.Contains(_search.ToLower())) return false;
            if(!string.IsNullOrEmpty(_filterType) &&
               j.JobType != _filterType) return false;
            if(!string.IsNullOrEmpty(_filterLocation) &&
               (j.Location == null || !j.Location.Contains(_filterLocation, StringComparison.OrdinalIgnoreCase))) return false;
            return true;
        }).ToList();
        StateHasChanged();
    }

    private async Task CreateAsync(){
        await _form!.ValidateAsync();
        if(!_valid) return;
        _saving = true;
        if(_deadline.HasValue) _dto.Deadline = DateOnly.FromDateTime(_deadline.Value);
        var (ok, err) = await Svc.CreateAsync(_dto);
        _saving = false;
        if(ok){
            Snackbar.Add("Job posted successfully!", Severity.Success);
            _showCreate = false;
            _dto = new() { JobType = "FullTime" };
            _deadline = null;
            _all = await Svc.GetAllAsync();
            ApplyFilters();
        }
        else Snackbar.Add(err ?? "Failed to post job.", Severity.Error);
    }

    private Color GetJobTypeColor(string t) => t switch{
        "Remote"   => Color.Info,
        "FullTime" => Color.Success,
        "PartTime" => Color.Warning,
        "Contract" => Color.Secondary,
         _ => Color.Default
    };
}
