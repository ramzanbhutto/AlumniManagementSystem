@page "/events"
@rendermode InteractiveWebAssembly
@inject NavigationManager Nav
@inject EventApiService Svc
@inject AuthService Auth
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>Events</PageTitle>

<MudStack Spacing="4">

    @* ── Header ── *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight:700;letter-spacing:-0.02em;color:#111827">Events</MudText>
            <MudText Typo="Typo.body2" Style="color:#6b7280">@_filtered.Count events</MudText>
        </div>
        @if(Auth.IsAdmin){
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.Add"
                       OnClick="@(() => _showCreate = true)"
                       Style="border-radius:10px;font-weight:600;text-transform:none;padding:0.5rem 1.25rem">
                Create Event
            </MudButton>
        }
    </MudStack>

    @* ── Filters ── *@
    <MudPaper Elevation="0" Style="background:#E8EAF6;border:1px solid #d1d5db;border-radius:14px;padding:1.1rem">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_search" Placeholder="Search events..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Immediate="true" @bind-Value:after="ApplyFilters" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <NativeSelect Label="Event Type" Value="@_filterType" BgColor="#E8EAF6"
                              ValueChanged="@((string? v) => { _filterType = v ?? ""; ApplyFilters(); })">
                    <option value="">All Types</option>
                    @foreach(var t in _types){
                        <option value="@t">@t</option>
                    }
                </NativeSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <NativeSelect Label="Status" Value="@_filterStatus" BgColor="#E8EAF6"
                              ValueChanged="@((string? v) => { _filterStatus = v ?? ""; ApplyFilters(); })">
                    <option value="">All Statuses</option>
                    @foreach(var s in _statuses){
                        <option value="@s">@s</option>
                    }
                </NativeSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudSwitch @bind-Value="_upcomingOnly" Color="Color.Primary"
                           Label="Upcoming only" LabelPosition="LabelPosition.End"
                           @bind-Value:after="ApplyFilters" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ── Cards grid ── *@
    @if(_loading){
        <MudGrid Spacing="3">
            @for(int i = 0; i < 6; i++){
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton Height="220px" Animation="Animation.Wave" Style="border-radius:14px" />
                </MudItem>
            }
        </MudGrid>
    }
    else if(!_filtered.Any()){
        <MudPaper Elevation="0" Style="background:#E8EAF6;border:1px solid #e5e7eb;border-radius:14px;padding:3rem;text-align:center">
            <MudIcon Icon="@Icons.Material.Rounded.EventBusy" Style="font-size:3.5rem;color:#9ca3af;margin-bottom:0.75rem" />
            <MudText Typo="Typo.body1" Style="color:#374151;font-weight:600">No events found</MudText>
            <MudText Typo="Typo.body2" Style="color:#6b7280;margin-top:0.25rem">Try adjusting your filters.</MudText>
        </MudPaper>
    }
    else{
        <MudGrid Spacing="3">
            @foreach(var e in _filtered){
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="event-card"
                              Style="background:#ffffff;border:1px solid #e5e7eb;border-radius:14px;padding:1.4rem;height:100%;transition:all 0.18s">
                        <MudStack Spacing="2" Style="height:100%">

                            @* Type + Status chips *@
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@GetTypeColor(e.EventType)"
                                         Style="font-size:0.68rem;height:20px;font-weight:600">
                                    @e.EventType
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@GetStatusColor(e.Status)"
                                         Style="font-size:0.68rem;height:20px;font-weight:600">
                                    @e.Status
                                </MudChip>
                            </MudStack>

                            @* Title *@
                            <MudText Typo="Typo.subtitle1"
                                     Style="font-weight:700;color:#111827;line-height:1.3">
                                @e.Title
                            </MudText>

                            @* Description *@
                            @if(e.Description != null){
                                <MudText Typo="Typo.body2"
                                         Style="color:#6b7280;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">
                                    @e.Description
                                </MudText>
                            }

                            <MudDivider Style="border-color:#f3f4f6;margin-top:auto" />

                            @* Date + Venue *@
                            <MudStack Row="true" Spacing="3" Class="flex-wrap">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Rounded.CalendarToday"
                                             Style="font-size:0.85rem;color:#9ca3af" />
                                    <MudText Typo="Typo.caption" Style="color:#6b7280;font-weight:500">
                                        @e.EventDate.ToString("MMM d, yyyy")
                                    </MudText>
                                </MudStack>
                                @if(e.Venue != null){
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Rounded.LocationOn"
                                                 Style="font-size:0.85rem;color:#9ca3af" />
                                        <MudText Typo="Typo.caption"
                                                 Style="color:#6b7280;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;font-weight:500">
                                            @e.Venue
                                        </MudText>
                                    </MudStack>
                                }
                            </MudStack>

                            @* RSVP row *@
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Rounded.Group"
                                             Style="font-size:0.85rem;color:#2563eb" />
                                    <MudText Typo="Typo.caption" Style="color:#2563eb;font-weight:600">
                                        @e.RsvpCount RSVPs
                                    </MudText>
                                    @if(e.Capacity.HasValue){
                                        <MudText Typo="Typo.caption" Style="color:#9ca3af">
                                            / @e.Capacity cap
                                        </MudText>
                                    }
                                </MudStack>

                                @if(e.Status == "Upcoming" && Auth.IsAlumni){
                                    @if(_myRsvps.Contains(e.EventId)){
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                 Variant="Variant.Filled"
                                                 Style="font-size:0.68rem;height:22px;font-weight:700">
                                            ✓ RSVPed
                                        </MudChip>
                                    }
                                    else{
                                        <MudButton Size="Size.Small" Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Style="border-radius:7px;text-transform:none;font-weight:600;font-size:0.75rem"
                                                   OnClick="@(() => DoRsvpAsync(e.EventId))">
                                            RSVP →
                                        </MudButton>
                                    }
                                }
                            </MudStack>

                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

</MudStack>

@* ══════════════════════════════════════════════════════
   CREATE EVENT DIALOG (Admin)
═══════════════════════════════════════════════════════ *@
@if(_showCreate && Auth.IsAdmin){
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="1000" />
    <div style="position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:1001;padding:1rem">
        <MudPaper Elevation="0"
                  Style="background:#ffffff;border:1px solid #e5e7eb;border-radius:18px;padding:2rem;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.15)">

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;color:#111827">Create Event</MudText>
                    <MudText Typo="Typo.caption" Style="color:#6b7280">Fill in the event details below</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small"
                               OnClick="@(() => _showCreate = false)" />
            </MudStack>

            <MudForm @ref="_form" @bind-IsValid="_valid">
                <MudStack Spacing="3">

                    <MudTextField @bind-Value="_dto.Title" Label="Event Title"
                                  Variant="Variant.Outlined" Required="true" RequiredError="Title is required"
                                  Margin="Margin.Dense" />

                    <MudTextField @bind-Value="_dto.Description" Label="Description"
                                  Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" />

                    @* Date + Time *@
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <label style="display:block;font-size:0.75rem;color:#6b7280;margin-bottom:4px;font-weight:500">
                                Event Date*
                            </label>
                            <input type="date"
                                   value="@_eventDate?.ToString("yyyy-MM-dd")"
                                   @onchange="@((ChangeEventArgs ev) => _eventDate = DateTime.TryParse(ev.Value?.ToString(), out var d) ? d : _eventDate)"
                                   style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;background:#f9fafb;font-size:0.875rem;color:#111827;font-family:inherit;outline:none;height:38px;box-sizing:border-box" />
                        </MudItem>
                        <MudItem xs="6">
                            <label style="display:block;font-size:0.75rem;color:#6b7280;margin-bottom:4px;font-weight:500">
                                Time
                            </label>
                            <input type="time"
                                   value="@(_eventTime?.ToString(@"hh\:mm"))"
                                   @onchange="@((ChangeEventArgs ev) => _eventTime = TimeSpan.TryParse(ev.Value?.ToString(), out var t) ? t : _eventTime)"
                                   style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;background:#f9fafb;font-size:0.875rem;color:#111827;font-family:inherit;outline:none;height:38px;box-sizing:border-box" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="_dto.Venue" Label="Venue"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <NativeSelect Label="Event Type*" Value="@_dto.EventType" BgColor="#f9fafb"
                                          ValueChanged="@((string? v) => _dto.EventType = v ?? "")">
                                <option value="">Select Type</option>
                                @foreach(var t in _types){
                                    <option value="@t">@t</option>
                                }
                            </NativeSelect>
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_dto.Capacity" Label="Capacity (optional)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          InputType="InputType.Number" />
                        </MudItem>
                    </MudGrid>

                    <div>
                        <label style="display:block;font-size:0.75rem;color:#6b7280;margin-bottom:4px;font-weight:500">
                            Registration Deadline (optional)
                        </label>
                        <input type="date"
                               value="@_regDeadline?.ToString("yyyy-MM-dd")"
                               @onchange="@((ChangeEventArgs ev) => _regDeadline = DateTime.TryParse(ev.Value?.ToString(), out var d) ? d : null)"
                               style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:6px;background:#f9fafb;font-size:0.875rem;color:#111827;font-family:inherit;outline:none;height:38px;box-sizing:border-box" />
                    </div>

                    <MudDivider />

                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Text" OnClick="@(() => _showCreate = false)"
                                   Style="text-transform:none">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="CreateAsync" Disabled="_saving"
                                   Style="border-radius:8px;text-transform:none;font-weight:600">
                            @if(_saving){
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Create Event
                        </MudButton>
                    </MudStack>

                </MudStack>
            </MudForm>
        </MudPaper>
    </div>
}

<style>
    .event-card:hover {
        border-color: #a5b4fc !important;
        box-shadow: 0 4px 20px rgba(99,102,241,0.1);
        transform: translateY(-1px);
    }
</style>

@code {
    private List<EventDto> _all      = [];
    private List<EventDto> _filtered = [];
    private HashSet<Guid>  _myRsvps  = [];
    private bool _loading = true;
    private bool _showCreate = false;
    private bool _saving= false;
    private bool _valid = false;
    private bool _upcomingOnly = false;
    private string _search       = "";
    private string _filterType   = "";
    private string _filterStatus = "";
    private MudForm?  _form;
    private CreateEventDto _dto = new();
    private DateTime? _eventDate= DateTime.Today.AddDays(7);
    private TimeSpan? _eventTime = new TimeSpan(18, 0, 0);
    private DateTime? _regDeadline = null;

    private string[] _types    = ["Reunion","Seminar","CareerFair","Social","Workshop"];
    private string[] _statuses = ["Upcoming","Ongoing","Completed","Cancelled"];

    protected override async Task OnAfterRenderAsync(bool firstRender){
        if(!firstRender) return;
        await Auth.InitAsync();
        if(!Auth.IsLoggedIn){ Nav.NavigateTo("/login"); return; }
        _all = await Svc.GetAllAsync();
        ApplyFilters();
        _loading = false;
        StateHasChanged();
    }

    private void ApplyFilters(){
        _filtered = _all.Where(e =>
        {
            if(!string.IsNullOrEmpty(_search) &&
               !e.Title.Contains(_search, StringComparison.OrdinalIgnoreCase)) return false;
            if(!string.IsNullOrEmpty(_filterType)   && e.EventType != _filterType)   return false;
            if(!string.IsNullOrEmpty(_filterStatus) && e.Status    != _filterStatus) return false;
            if(_upcomingOnly && e.Status != "Upcoming") return false;
            return true;
        }).ToList();
        StateHasChanged();
    }

    private async Task CreateAsync(){
        await _form!.ValidateAsync();
        if(string.IsNullOrEmpty(_dto.EventType)){
            Snackbar.Add("Please select an Event Type.", Severity.Warning);
            return;
        }
        if(!_valid) return;
        _saving = true;
        if(_eventDate.HasValue) _dto.EventDate = _eventDate.Value.Add(_eventTime ?? TimeSpan.Zero);
        if(_regDeadline.HasValue) _dto.RegistrationDeadline = _regDeadline;
        var (ok, err) = await Svc.CreateAsync(_dto);
        _saving = false;
        if(ok){
            Snackbar.Add("Event created!", Severity.Success);
            _showCreate = false;
            _dto = new();
            _eventDate  = DateTime.Today.AddDays(7);
            _eventTime  = new TimeSpan(18, 0, 0);
            _regDeadline = null;
            _all = await Svc.GetAllAsync();
            ApplyFilters();
        }
        else Snackbar.Add(err ?? "Error creating event.", Severity.Error);
    }

    private async Task DoRsvpAsync(Guid eventId){
        var (ok, err) = await Svc.RsvpAsync(eventId);
        if(ok){
            _myRsvps.Add(eventId);
            _all = await Svc.GetAllAsync();
            ApplyFilters();
            Snackbar.Add("RSVP confirmed!", Severity.Success);
        }
        else Snackbar.Add(err ?? "Failed to RSVP.", Severity.Error);
    }

    private Color GetTypeColor(string t) => t switch{
        "Reunion"  => Color.Primary,
        "Seminar" => Color.Info,
        "CareerFair" => Color.Success,
        "Social"     => Color.Secondary,
        _  => Color.Default
    };
    private Color GetStatusColor(string s) => s switch{
        "Upcoming"  => Color.Success,
        "Ongoing"   => Color.Warning,
        "Completed" => Color.Default,
        _  => Color.Error
    };
}
