<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alumni Management System</title>
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" /> 
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <style>
           body, * { font-family: 'DM Sans', system-ui, sans-serif !important; }
           body { background: #f8fafc !important; margin: 0; }
          .mud-drawer { border-right: 1px solid #e8edf3 !important; }
          .mud-appbar { box-shadow: none !important; border-bottom: 1px solid #e8edf3 !important; }
          .ams-logout-btn:hover { background: #fef2f2 !important; }
          .ams-nav-item:hover { background: #f1f5f9 !important; }
     </style> 
    <HeadOutlet />
</head>
<body>
    <Routes />
    @* MudBlazor needs these portal targets at the document body level.
       Without them, MudSelect dropdowns and MudDialog are invisible in
       Blazor Web App (WASM render mode) because popovers/dialogs are
       teleported outside the Blazor component tree. *@
    <div id="mud-popover-provider"></div>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        window.clearAuthStorage = function () {
            ['ams_token','ams_role','ams_name','ams_uid','ams_aid']
                .forEach(k => localStorage.removeItem(k));
        }
    </script>
</body>
</html>
